# apps/scan — copy to .env (local dev) or .env.test (integration tests)

# Server
PORT=8788

# Supabase — both keys required
SUPABASE_URL=https://scryfkefedzuetfdtrvl.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Platform API keys (real values for local dev; not needed in CI — tests use fake adapters)
RAPIDAPI_KEY=<your-rapidapi-key>
YOUTUBE_API_KEY=<your-youtube-data-api-v3-key>
OPENROUTER_API_KEY=<your-openrouter-api-key>

# OpenRouter model (default used when env var absent)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Set to '1' to use fake fetch+LLM adapters end-to-end (Plan 4 E2E / fixture mode)
SCAN_FIXTURE_MODE=
