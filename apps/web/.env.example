# Supabase read-model (public, client-safe anon key)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Canonical site origin for SEO (canonical/hreflang/sitemap/JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.kinnso.ai
# Shared secret for POST /api/revalidate (must equal apps/sync REVALIDATE_SECRET)
REVALIDATE_SECRET=<shared-secret>
# Public base URL of the scan worker (apps/scan). Auth is the per-request bearer
# token, NOT a secret — this value is safe to expose to the browser.
NEXT_PUBLIC_SCAN_URL=http://localhost:8788

# Travelpayouts affiliate network integration (server-only; never prefix with NEXT_PUBLIC_)
TRAVELPAYOUTS_API_TOKEN=replace_with_rotated_token_before_production
TRAVELPAYOUTS_PROJECT_ID=replace_with_travelpayouts_trs
TRAVELPAYOUTS_MARKER=replace_with_travelpayouts_marker
# Server-only Supabase key for trusted server actions. Never expose in browser code.
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# Creator Copilot (Phase 5C). LLM calls route through the Vercel AI Gateway.
# Local/CI only — on Vercel deployments the gateway authenticates via OIDC (no key needed).
AI_GATEWAY_API_KEY=replace_with_vercel_ai_gateway_key
# Hosted n8n webhook the Copilot calls as a tool (server-only). Leave unset to disable the tool gracefully.
N8N_COPILOT_URL=
N8N_COPILOT_TOKEN=
